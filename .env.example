# ---- Postgres ----
POSTGRES_USER=asb
POSTGRES_PASSWORD=asb_dev_password
POSTGRES_DB=asb

# ---- Redis ----
REDIS_PASSWORD=

# ---- Backend ----
# Used inside docker-compose; for local dev outside Docker see apps/backend/.env.example
DATABASE_URL=postgresql://asb:asb_dev_password@postgres:5432/asb?schema=public
REDIS_URL=redis://redis:6379
BACKEND_PORT=3000
NODE_ENV=production

# Strong random (>= 32 chars). Used to sign JWTs.
JWT_SECRET=change-me-to-a-long-random-string-change-me-change-me

# Telegram webhook verification (X-Telegram-Bot-Api-Secret-Token). Required.
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret

# Optional default bot token (per-user token stored in Settings overrides this)
TELEGRAM_BOT_TOKEN=

# Default LLM (per-user Settings override these)
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Deepgram STT
DEEPGRAM_API_KEY=

# Todoist
TODOIST_API_KEY=

# CORS origin for frontend
FRONTEND_ORIGIN=http://localhost:8080

# ---- Frontend (build-time) ----
VITE_API_BASE_URL=http://localhost:3000
