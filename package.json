{
  "name": "agent-second-brain",
  "version": "2.0.0",
  "private": true,
  "description": "Full-stack personal second brain: Telegram capture -> Postgres knowledge graph -> React dashboard",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "backend": "pnpm --filter @asb/backend",
    "frontend": "pnpm --filter @asb/frontend"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
